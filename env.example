# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
# In DEBUG mode the backend auto-allows the machine's hostname and any LAN IPs,
# plus "*". In production, list every host the API will be reached as.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.maishachat.or.tz

# CORS / CSRF (frontend origins). The backend auto-appends
# http(s)://<hostname>:<FRONTEND_DEV_PORT> for every detected dev hostname/IP.
FRONTEND_DEV_PORT=3090
CORS_ALLOWED_ORIGINS=http://localhost:3090,https://maishachat.or.tz
CSRF_TRUSTED_ORIGINS=https://maishachat.or.tz,https://api.maishachat.or.tz

# SQLite (default: ./db.sqlite3 inside bd-backend)
# Uncomment to override the database file location.
# DB_PATH=/absolute/path/to/maishachat.sqlite3

# JWT
JWT_ACCESS_MIN=60
JWT_REFRESH_DAYS=14

# LLM
HF_HOME=/home/happiness/blood_donation_ai/models
TRANSFORMERS_CACHE=/home/happiness/blood_donation_ai/models
# Install GPU PyTorch separately (driver 535 / CUDA 12.2 example):
#   pip install 'torch>=2.5.1,<2.7' --index-url https://download.pytorch.org/whl/cu121
TORCH_DTYPE=auto
LLM_DEVICE_MAP=auto
# auto | cpu | cuda
# On shared GPU machines, use auto (default) or cpu. Maisha never stops other users' jobs.
LLM_DEVICE=auto
LLM_MAX_NEW_TOKENS=512
# Shorter cap when running on CPU keeps chat responsive on shared hosts.
LLM_MAX_NEW_TOKENS_CPU=256
LLM_CPU_THREADS=0
